N8N_PORT=5678
N8N_HOST=localhost
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/
GENERIC_TIMEZONE=America/Chicago

# Generate locally and never commit the real value:
# openssl rand -hex 32
N8N_ENCRYPTION_KEY=replace-with-local-random-value

# n8n execution pruning in hours. 336 = 14 days.
EXECUTIONS_DATA_MAX_AGE=336

# Optional: used by local commands/MCP tools that poll GitHub for repository and merge events.
# Use a local read-only token. Never commit the real value.
MCP_COMPLIANCE_SCAN_GITHUB_TOKEN=replace-with-local-github-token
